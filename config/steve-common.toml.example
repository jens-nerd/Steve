[ai]
    # AI provider to use: 'claude' (default), 'groq', 'openai', or 'gemini'
    provider = "claude"

[anthropic]
    # Your Anthropic (Claude) API key
    # Get your API key from: https://console.anthropic.com/settings/keys
    apiKey = "your-anthropic-api-key-here"

    # Claude model: claude-haiku-4-5 (fastest/cheapest), claude-sonnet-4-6, claude-opus-4-8
    model = "claude-haiku-4-5"

[openai]
    # Your OpenAI API key
    # Get your API key from: https://platform.openai.com/api-keys
    apiKey = "your-openai-api-key-here"

    # Using GPT-3.5-turbo (much cheaper than GPT-4 for testing)
    model = "gpt-3.5-turbo"

    # Maximum tokens per API request
    maxTokens = 1000

    # Temperature (0.0-2.0, lower is more deterministic)
    temperature = 0.7

[behavior]
    # Ticks between action checks (20 ticks = 1 second)
    actionTickDelay = 20
    
    # Allow Steves to respond in chat
    enableChatResponses = true
    
    # Maximum number of Steves that can be active simultaneously
    maxActiveSteves = 10

